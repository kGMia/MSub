    "help.beam" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Model decoding beam width. Larger can be steadier but slower; 3 or 4 is usually enough locally."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "模型解码搜索宽度。更大可能略稳但更慢；本地实时调试通常 3 或 4 足够。"
          }
        }
      }
    },
    "help.confidence" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drops recognized pieces below this confidence. No effect if the model does not return confidence; raise slightly for noisy audio."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "丢弃低于此置信度的识别片段。模型不返回置信度时不会生效；嘈杂素材可略微调高。"
          }
        }
      }
    },
    "help.fixedChunk" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chunk length used by fixed mode. It mostly does not affect VAD mode."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "固定切片模式下每段时长。VAD 模式下基本不影响结果。"
          }
        }
      }
    },
    "help.format" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SRT/VTT are subtitle formats, TXT is a plain transcript, JSON is best for downstream tooling."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SRT/VTT 用于字幕软件，TXT 用于纯文本稿，JSON 用于后续程序处理。"
          }
        }
      }
    },
    "help.lineChars" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Subtitle line wrapping width. 14-20 works well for Chinese; set 0 to disable wrapping."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "字幕换行宽度。中文通常 14-20 较舒服，设为 0 可关闭自动换行。"
          }
        }
      }
    },
    "help.maxSegment" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maximum duration for one recognition segment. Shorter gives tighter subtitles; too short can lose context."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "单个识别分段允许的最长时间。越短字幕越碎、越贴近语音；过短可能损失上下文。"
          }
        }
      }
    },
    "help.minSegment" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiny split remainders below this are merged. Lower it to keep more short subtitles."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "切分后过短的小段会被合并。降低它会保留更多短字幕。"
          }
        }
      }
    },
    "help.minSpeech" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detected speech shorter than this is treated as noise. Raise for noisy audio; lower for quiet speech."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "短于此值的语音活动会被视为噪声。嘈杂素材可调高，低音量语音可调低。"
          }
        }
      }
    },
    "help.mode" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VAD segments by detected speech activity and is usually better for subtitle sync; fixed chunks are a fallback."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VAD 会按实际语音活动分段，通常更适合字幕同步；固定切片只作为回退方案。"
          }
        }
      }
    },
    "help.model" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hugging Face model id or local model directory. Use the local FireRedASR2-AED-mlx path to avoid network downloads."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hugging Face 模型 ID 或本地模型目录。当前建议使用本地 FireRedASR2-AED-mlx 权重路径，避免联网下载。"
          }
        }
      }
    },
    "help.padding" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Extra time before and after each segment. More avoids clipped words; less makes subtitles tighter."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "给每段开头和结尾额外保留的时间。增加可避免吞字，减少可让字幕出现/消失更贴合语音。"
          }
        }
      }
    },
    "help.preset" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applies a starting point for segmentation and recognition settings. You can still fine-tune manually."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一键调整下方分段和识别参数。预设只是起点，仍可继续手动微调。"
          }
        }
      }
    },
    "help.search" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Search window around a long-segment cut point for the quietest frame. Larger can find more natural cuts."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "长分段切开时，在目标切点附近搜索最安静位置的范围。增大可找到更自然切点。"
          }
        }
      }
    },
    "help.silence" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silences shorter than this are bridged. Lower values split more; higher values merge more."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "短于此值的静音会被合并到同一段。调小会切得更碎，调大会减少碎片。"
          }
        }
      }
    },
    "help.threshold" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speech energy threshold. Higher is stricter and reduces noise; lower catches quieter speech."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "语音能量阈值。数值越高越严格，噪声更少但可能漏掉轻声；数值越低越灵敏。"
          }
        }
      }
    },
