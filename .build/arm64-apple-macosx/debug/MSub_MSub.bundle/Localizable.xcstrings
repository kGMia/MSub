    "preset.fastCut.help" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shortens max segments and silence bridging for short utterances, fast edits, and finer subtitles."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "缩短最大分段和静音合并，适合短句、快节奏剪辑和需要更碎字幕的场景。"
          }
        }
      }
    },
    "preset.lowVoice" : {
