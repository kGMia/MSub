          "stringUnit" : {
            "state" : "translated",
            "value" : "现场对话"
          }
        }
      }
    },
    "preset.dialogue.help" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Splits more actively around pauses, useful for live dialogue, interviews, and meetings."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更积极地按停顿切分，适合多人现场对话、访谈和会议片段。"
          }
        }
      }
    },
    "preset.fastCut" : {
