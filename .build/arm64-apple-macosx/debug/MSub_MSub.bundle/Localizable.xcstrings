      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "General defaults for clear recordings, ordinary speaking pace, and most videos."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通用默认值。适合清晰录音、普通语速和多数视频。"
          }
        }
      }
    },
    "preset.dialogue" : {
      "extractionState" : "stale",
